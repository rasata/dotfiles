#!/usr/bin/env bash
#/ Normalize ChatGPT output to plain text or markdown.
#/
#/ Usage: $(basename "$0") [-h] [-v] [-m plain|markdown] [--edit] [--clipboard] [--from-clipboard] <plain|markdown>
#/
#/ Available options:
#/    -h, --help      Print this help and exit
#/    -v, --verbose   Enable verbose output
#/    -m, --mode      Output mode: plain or markdown
#/    -e, --edit      Open temp file in nano, then clean and copy to clipboard
#/    --clipboard     Copy output to clipboard (pbcopy)
#/    --from-clipboard Read input from clipboard (pbpaste)
#/    --plain         Shortcut for --mode plain
#/    --markdown      Shortcut for --mode markdown
#/
#/ Examples:
#/    pbpaste | $(basename "$0") plain
#/    pbpaste | $(basename "$0") --markdown
#/    cat output.txt | $(basename "$0") -m markdown
#/    $(basename "$0") --edit markdown
#/    pbpaste | $(basename "$0") --clipboard plain
#/    $(basename "$0") --from-clipboard markdown

set -Eeuo pipefail
trap cleanup SIGINT SIGTERM ERR EXIT

source "$(dirname "$0")/../lib/bash/initrc"

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd -P)

verbose=0
mode=""
edit=0
clipboard=0
from_clipboard=0
temp_file=""

cleanup() {
  if [[ -n ${temp_file:-} && -f ${temp_file:-} ]]; then
    rm -f -- "$temp_file"
  fi
  script.cleanup
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      script.usage
      ;;
    -v | --verbose)
      verbose=1
      ;;
    -m | --mode)
      shift
      if [[ $# -eq 0 ]]; then
        log.error "Missing value for --mode"
        script.usage 1
      fi
      mode="$1"
      ;;
    -e | --edit)
      edit=1
      ;;
    --clipboard | --clipboar)
      clipboard=1
      ;;
    --from-clipboard)
      from_clipboard=1
      ;;
    --plain)
      mode="plain"
      ;;
    --markdown)
      mode="markdown"
      ;;
    --)
      shift
      break
      ;;
    --*)
      log.error "Unknown option: $1"
      script.usage 1
      ;;
    *)
      if [[ -z $mode ]]; then
        mode="$1"
      else
        log.error "Unexpected argument: $1"
        script.usage 1
      fi
      ;;
    esac
    shift
  done

  if [[ $# -gt 0 ]]; then
    log.error "Unexpected extra arguments: $*"
    script.usage 1
  fi

  if [[ -z $mode ]]; then
    log.error "Mode is required (plain or markdown)"
    script.usage 1
  fi

  case "$mode" in
  plain | markdown) ;;
  *)
    log.error "Mode must be plain or markdown, got: $mode"
    script.usage 1
    ;;
  esac
}

main() {
  ((verbose)) && log.info "Verbose mode enabled"

  guards.require_exec python3

  ((verbose)) && log.info "Mode: $mode"

  local -a py_args=("$mode")
  if ((edit)); then
    if ((from_clipboard)); then
      guards.require_exec pbpaste
    fi
    guards.require_exec nano
    temp_file=$(fs.mktmp file chatgpt-clean)
    if ((from_clipboard)); then
      ((verbose)) && log.info "Seeding temp file from clipboard"
      pbpaste >"$temp_file"
    fi
    ((verbose)) && log.info "Opening temp file in nano: $temp_file"
    nano "$temp_file"
    py_args+=("$temp_file")
  else
    if ((from_clipboard)); then
      guards.require_exec pbpaste
    elif [[ -t 0 ]]; then
      log.error "Expected input on stdin (or use --edit)"
      script.usage 1
    fi
  fi

  local do_clipboard=0
  if ((edit || clipboard)); then
    do_clipboard=1
  fi

  local can_clipboard=0
  if ((do_clipboard)) && command -v pbcopy >/dev/null 2>&1; then
    can_clipboard=1
  elif ((do_clipboard)); then
    log.warn "pbcopy not found; output not copied to clipboard"
  fi

  local py_code
  py_code="$(cat <<'PY'
import re
import sys

mode = sys.argv[1] if len(sys.argv) > 1 else "plain"
path = sys.argv[2] if len(sys.argv) > 2 else ""
if path:
  with open(path, "r", encoding="utf-8") as f:
    text = f.read()
else:
  text = sys.stdin.read()
if not text:
  sys.exit(0)

trans = {
  ord("\u201c"): '"',
  ord("\u201d"): '"',
  ord("\u201e"): '"',
  ord("\u00ab"): '"',
  ord("\u00bb"): '"',
  ord("\u2018"): "'",
  ord("\u2019"): "'",
  ord("\u201a"): "'",
  ord("\u201b"): "'",
  ord("\u2032"): "'",
  ord("\u2033"): '"',
  ord("\u2010"): "-",
  ord("\u2011"): "-",
  ord("\u2012"): "-",
  ord("\u2013"): "-",
  ord("\u2014"): "--",
  ord("\u2015"): "--",
  ord("\u2e3b"): "--",
  ord("\u2212"): "-",
  ord("\u2026"): "...",
  ord("\u00a0"): " ",
  ord("\u2022"): "-",
  ord("\u2023"): "-",
  ord("\u2043"): "-",
  ord("\u2219"): "-",
  ord("\u00b7"): "-",
  ord("\u25e6"): "-",
  ord("\u25aa"): "-",
  ord("\u25cf"): "-",
  ord("\u25c9"): "-",
  ord("\u25cb"): "-",
  ord("\u25b8"): "-",
}

text = text.translate(trans)
text = text.replace("\r\n", "\n").replace("\r", "\n")
text = text.replace("\t", "  ")

def normalize_line(line: str) -> str:
  line = line.rstrip()
  m = re.match(r"^(\s*)(\d+)[\.\)]\s*(.*)$", line)
  if m:
    indent, num, rest = m.groups()
    rest = rest.lstrip()
    if rest:
      return f"{indent}{num}. {rest}".rstrip()
    return f"{indent}{num}."
  m = re.match(r"^(\s*)[-*+]\s*(.*)$", line)
  if m:
    indent, rest = m.groups()
    rest = rest.lstrip()
    if rest:
      return f"{indent}- {rest}".rstrip()
    return f"{indent}-"
  return line

def is_list_line(line: str) -> bool:
  return bool(re.match(r"^\s*(?:-|\d+\.)\s+\S", line))

lines = [normalize_line(line) for line in text.splitlines()]

if mode == "markdown":
  out = []
  prev_nonempty_is_list = False
  for line in lines:
    is_empty = not line.strip()
    is_list = is_list_line(line)
    if is_list and out and out[-1].strip() and not prev_nonempty_is_list:
      out.append("")
    out.append(line)
    if not is_empty:
      prev_nonempty_is_list = is_list
  lines = out

sys.stdout.write("\n".join(lines).rstrip() + "\n")
PY
)"

  if ((can_clipboard)); then
    if ((edit)); then
      python3 -c "$py_code" "${py_args[@]}" | tee >(pbcopy)
    elif ((from_clipboard)); then
      pbpaste | python3 -c "$py_code" "${py_args[@]}" | tee >(pbcopy)
    else
      python3 -c "$py_code" "${py_args[@]}" | tee >(pbcopy)
    fi
  else
    if ((edit)); then
      python3 -c "$py_code" "${py_args[@]}"
    elif ((from_clipboard)); then
      pbpaste | python3 -c "$py_code" "${py_args[@]}"
    else
      python3 -c "$py_code" "${py_args[@]}"
    fi
  fi
}

parse_args "$@"
main
